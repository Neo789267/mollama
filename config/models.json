              "temperature": 1
            },
            "disabled": {
              "temperature": 0.6
            }
          },
          "reasoningHistory": {
            "mode": "none"
          }
        }
      ]
    },
    "mimo": {
      "upstream": {
        "baseUrl": "https://token-plan-cn.xiaomimimo.com/v1",
        "apiKey": "env:MIMO_API_KEY",
        "timeoutMs": 120000,
        "retry": {
          "attempts": 1,
          "backoffMs": 150,
          "retryOnStatusCodes": [429, 500, 502, 503, 504]
        },
        "headers": {
          "api-key": ""
        }
      },
      "models": [
        {
          "id": "mimo-v2-5-pro-local",
